# Next.js dev server
HOST=0.0.0.0
PORT=11830

# llama-server (OpenAI-compatible API)
LLAMA_SERVER_URL=http://localhost:11434/v1

# ComfyUI endpoint
COMFY_URL=http://localhost:11820

# Model name (must be vision-capable for both text and vision tasks)
MODEL=Qwen3-VL-8B-Instruct

# Number of scenes to generate (4-6 recommended)
SCENE_COUNT=6

# Maximum retry attempts per scene when vision check fails
MAX_RETRIES=2

# Style prefix prepended to all ComfyUI prompts
STYLE_PREFIX="cinematic still, 4k, detailed, sharp focus,"

# ComfyUI workflow file (relative to project root)
WORKFLOW_FILE=workflows/workflow_zimage_turbo.json

# Node ID in workflow that holds the positive prompt
PROMPT_NODE_ID=70

# Output directory for generated images (relative to public/)
OUTPUT_DIR=output
